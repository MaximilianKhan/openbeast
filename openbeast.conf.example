# OpenBeast configuration — copy to "openbeast.conf" and edit.
#
#   cp openbeast.conf.example openbeast.conf
#
# openbeast.conf is gitignored, so your local paths never get committed.

# Where your .gguf model weights live. Weights are large and are NOT stored in
# the repo — put them wherever you have space (NVMe, USB, NAS mount, etc.) and
# point OpenBeast at them here.
#
# Accepts absolute paths, ~ for your home dir, or a path relative to the repo.
# Resolution order (first match wins): the $OPENBEAST_WEIGHTS_DIR env var
# overrides everything (per-shell override), then WEIGHTS_DIR set here, then
# an existing ./weights/ inside the repo, then ../weights next to the repo.
#
# Examples:
#   WEIGHTS_DIR=/mnt/nvme/gguf
#   WEIGHTS_DIR=~/models/gguf
#   WEIGHTS_DIR=/run/media/max/USB-SSD/weights
#   WEIGHTS_DIR=/mnt/nas/ai/weights

WEIGHTS_DIR=../weights

# ---------------------------------------------------------------------------
# Network / remote access  (see docs/REMOTE_ACCESS_PLAN.md and
# scripts/setup-tailscale.sh — one command sets up secure access from
# anywhere via Tailscale)
# ---------------------------------------------------------------------------

# Address the stack's services bind to. Default (even without this file) is
# 127.0.0.1: loopback-only, with remote devices coming in through Tailscale
# Serve's authenticated HTTPS proxy. Set 0.0.0.0 to restore the legacy
# LAN-open behavior (any device on your network can reach every service,
# unauthenticated — not recommended).
#BIND_HOST=127.0.0.1

# Optional: require "Authorization: Bearer <key>" on the llama-server API.
# Off by default — the tailnet is already the security boundary, and the
# eval harness / agents don't send a key yet. Enable if your tailnet has
# other users.
#LLAMA_API_KEY=

# Open WebUI login. Default OFF for local-only single-user installs (no
# login wall; configure-webui.sh auto-configures via the default admin
# account). scripts/setup-tailscale.sh sets this to true automatically when
# the WebUI goes tailnet-wide — that's when a per-user login + the RBAC
# tiers (docs/RBAC_PLAN.md) start to matter.
#WEBUI_AUTH=false

# Open WebUI admin credentials, used by scripts/configure-webui.sh to apply
# tool-server + native function-calling config when WEBUI_AUTH is on.
# Create the account in the browser on first visit, then mirror it here.
#WEBUI_ADMIN_EMAIL=
#WEBUI_ADMIN_PASSWORD=
